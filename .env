# IntelliFlow v2.0 Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
FLASK_SECRET_KEY=change-me-in-production-use-secrets-manager
JWT_SECRET=change-me-in-production-use-secrets-manager
FRONTEND_URL=https://intelli-flow-brown.vercel.app
ALLOWED_ORIGINS=https://intelli-flow-brown.vercel.app,http://localhost:5173
PORT=5000

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-api-key
BIGQUERY_DATASET=intelliflow_data

# ─── Paystack (https://dashboard.paystack.com) ────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# ─── Database (production) ────────────────────────────────────────────────────
# Supabase (recommended)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# PostgreSQL direct (alternative)
DATABASE_URL=postgresql://user:password@host:5432/intelliflow

# ─── Redis (production caching) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO

# ─── Email (transactional) ────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@intelliflow.ai
