# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV="development"
ENVIRONMENT="development"
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL: Use the connection pooler URL (port 6543, transaction mode)
# DIRECT_URL:   Use the direct connection URL (port 5432) for migrations
#
# Example:
# DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.xxxxx:password@aws-0-region.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/busara"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/busara"

# ─── App URL (used for Flutterwave redirect & PWA manifest) ──────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Flutterwave Payments (https://dashboard.flutterwave.com/dashboard/settings/apis) ───
# Leave blank to run in mock mode (free plan flow simulated).
FLW_SECRET_KEY=""
FLW_PUBLIC_KEY=""
FLW_ENCRYPTION_KEY=""
# Set this in Flutterwave dashboard: Settings → Webhooks → Secret Hash
FLW_WEBHOOK_HASH=""

# ─── WebSocket Mini-Service ──────────────────────────────────────────────────
WS_SERVER_URL="http://localhost:3003"

# ─── Supabase Auth (Optional — replaces custom JWT if configured) ───────────
# Get these from: Supabase Dashboard → Project Settings → API
# If set, Supabase Auth is tried first; custom JWT is the fallback.
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── AI / LLM Multi-Provider Router ─────────────────────────────────────────
# Busara v6.0 supports multiple LLM providers with automatic fallback.
# The bundled z-ai-web-dev-sdk (GLM-4.6) is always available.
# Set these to enable additional providers:
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_GEMINI_API_KEY=""

# ─── Data Connectors (Phase 1) ──────────────────────────────────────────────
# No env vars needed — connection strings are passed per-request via API.
# The /api/connectors endpoint accepts: postgresql, google_sheets, bigquery, rest_api

# ─── SSO via WorkOS (Phase 1) ───────────────────────────────────────────────
# Get keys at https://dashboard.workos.com
# WORKOS_API_KEY=""
# WORKOS_CLIENT_ID=""
# WORKOS_REDIRECT_URI=""

# ─── Optional: Analytics ─────────────────────────────────────────────────────
# POSTHOG_KEY=""
# POSTHOG_HOST=""
