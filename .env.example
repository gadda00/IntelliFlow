# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
ENVIRONMENT="development"
NODE_ENV="development"

# ─── App URL (used for Paystack callback) ────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Paystack (https://dashboard.paystack.com/settings/developers) ───────────
# Leave blank to run in mock mode (free plan flow simulated).
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
# Optional: pre-create plans in Paystack dashboard and reference their codes here
PAYSTACK_PRO_PLAN_CODE=""
PAYSTACK_TEAM_PLAN_CODE=""

# ─── WebSocket Mini-Service ──────────────────────────────────────────────────
# Internal URL of the WebSocket server (used by API routes to broadcast updates)
WS_SERVER_URL="http://localhost:3003"

# ─── Analytics / LLM (optional, future use) ──────────────────────────────────
# GOOGLE_GEMINI_API_KEY=""
# OPENAI_API_KEY=""
