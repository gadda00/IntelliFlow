// Busara v3.3 — Production Prisma schema (PostgreSQL on Supabase)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String?
  plan         String        @default("free")
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  apiKeys      ApiKey[]
  analyses     Analysis[]
  payments     Payment[]
  subscription Subscription?
  usageRecords UsageRecord[]
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keyHash   String   @unique
  prefix    String
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Analysis {
  id          String    @id @default(cuid())
  userId      String
  name        String
  dataSource  String
  config      String
  status      String    @default("pending")
  result      String?
  errorMessage String?
  agentRuns   AgentRun[]
  payment     Payment?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([status])
}

model AgentRun {
  id          String   @id @default(cuid())
  analysisId  String
  agentId     String
  agentName   String
  status      String   @default("pending")
  stage       Int
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  result      String?
  error       String?
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  @@index([analysisId])
  @@index([agentId])
}

model Payment {
  id              String      @id @default(cuid())
  userId          String
  reference       String      @unique
  amount          Int
  currency        String      @default("NGN")
  plan            String
  status          String      @default("initialized")
  provider        String      @default("flutterwave")
  providerData    String?
  analysisId      String?     @unique
  analysis        Analysis?   @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  verifiedAt      DateTime?
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([status])
}

model Subscription {
  id                    String   @id @default(cuid())
  userId                String   @unique
  plan                  String
  status                String   @default("active")
  providerSubCode       String?  @unique
  providerPlanCode      String?
  currentPeriodEnd      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id             String   @id @default(cuid())
  userId         String
  month          String
  analysesUsed   Int      @default(0)
  tokensUsed     Int      @default(0)
  agentsInvoked  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, month])
  @@index([userId])
}

model AgentMetric {
  id          String   @id @default(cuid())
  agentId     String
  analysisId  String?
  durationMs  Int
  success     Boolean
  errorType   String?
  createdAt   DateTime @default(now())
  @@index([agentId])
  @@index([createdAt])
}
